# ============================================
# Backend Environment Variables
# Copy file này thành .env và điền giá trị thực
# ============================================

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017

# Cổng server (host như Render/Railway sẽ tự cấp PORT). Mặc định 3000.
PORT=3000

# Token bảo vệ route /sync (ghi đè toàn bộ DB). Để trống = khoá /sync.
# Khi cần sync: gọi GET /sync?token=<giá trị này>
SYNC_TOKEN=
