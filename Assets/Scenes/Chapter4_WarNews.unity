  m_Script: {fileID: 11500000, guid: 61fd73836a1c5484dac169c0b9605f86, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuanLyHoiThoai
  kichBan:
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=yellow>L\xEDnh li\xEAn l\u1EA1c:</color> C\u1EA5p b\xE1o...!!
      Tuy\u1EBFn ph\xF2ng th\u1EE7 bi\xEAn gi\u1EDBi \u0111\xE3 v\u1EE1! Nh\u01B0ng
      b\u1EA9m b\u1EC7 h\u1EA1... b\u1ECDn ch\xFAng... b\u1ECDn ch\xFAng kh\xF4ng
      c\xF2n l\xE0 ng\u01B0\u1EDDi n\u1EEFa!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=white>Quan V\u0103n:</color> Ng\u01B0\u01A1i \u0111i\xEAn
      r\u1ED3i sao? D\xE1m n\xF3i n\u0103ng h\u1ED3 \u0111\u1ED3 tr\u01B0\u1EDBc
      m\u1EB7t b\u1EC7 h\u1EA1!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=yellow>L\xEDnh li\xEAn l\u1EA1c:</color> Th\u1EA7n n\xF3i
      th\u1EADt! Qu\xE2n th\xE1t \u0111\u1ED3n r\u1EB1ng \u0111\xE3 nu\u1ED1t ph\u1EA3i
      'Tr\xE1i C\u1EA5m'. B\u1ECDn ch\xFAng gi\u1EDD l\xE0 nh\u1EEFng sinh v\u1EADt
      qu\xE1i d\u1ECB... k\u1EBB th\xEC nanh vu\u1ED1t t\xE0n b\u1EA1o, k\u1EBB th\xEC
      ch\u1EC9 c\xF2n x\u01B0\u01A1ng kh\xF4 v\xF4 h\u1ED3n!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=white>Quan V\u0103n:</color> Tr\u1EDDi \u0111\u1EA5t \u01A1i...
      N\u1EBFu l\xE0 y\xEAu ma qu\u1EF7 qu\xE1i th\xEC s\u1EE9c ng\u01B0\u1EDDi sao
      ch\u1ED1ng \u0111\u1EE1 n\u1ED5i? B\u1EC7 h\u1EA1, xin h\xE3y mau ch\xF3ng
      d\u1EDDi \u0111\xF4 \u0111\u1EC3 b\u1EA3o to\xE0n huy\u1EBFt m\u1EA1ch!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=red>Quan V\xF5:</color> D\xF9 ch\xFAng c\xF3 l\xE0 \xE1c
      qu\u1EF7 \u0111\u1ECBa ng\u1EE5c, \u0111\xE2y v\u1EABn l\xE0 \u0111\u1EA5t
      t\u1ED5 ti\xEAn! K\u1EBB n\xE0o s\u1EE3 ch\u1EBFt b\xE0n l\xF9i, ta s\u1EBD
      t\u1EF1 tay ch\xE9m \u0111\u1EA7u!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=orange>Vua Tr\u1EA7n Th\xE1i T\xF4ng:</color> B\xECnh t\u0129nh!
      Gi\u1EB7c c\u1EADy t\xE0 thu\u1EADt l\xE0m lo\u1EA1n, nh\u01B0ng \u0110\u1EA1i
      Vi\u1EC7t ta c\xF3 ch\xEDnh ngh\u0129a v\xE0 \xFD ch\xED s\u1EAFt \u0111\xE1.
      Giao giang s\u01A1n cho \xE1c qu\u1EF7, b\xE1ch t\xEDnh s\u1EBD s\u1ED1ng sao?\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=#00FFFF>Tr\u1EA7n Qu\u1ED1c Tu\u1EA5n:</color> Mu\xF4n
      t\xE2u b\u1EC7 h\u1EA1! L\u0169 qu\xE1i v\u1EADt kia d\u1EABu cu\u1ED3ng b\u1EA1o
      nh\u01B0ng hoang d\xE3, \u1EAFt thi\u1EBFu m\u01B0u l\u01B0\u1EE3c. Th\u1EA7n
      xin l\u0129nh \u1EA5n ti\xEAn phong, tr\u1EF1c ti\u1EBFp \u0111\u1ED1i \u0111\u1EA7u
      xem th\u1EF1c h\u01B0 s\u1EE9c m\u1EA1nh c\u1EE7a ch\xFAng!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=orange>Vua Tr\u1EA7n Th\xE1i T\xF4ng:</color> Kh\xE1 l\u1EAFm!
      Ti\u1EBFng tr\u1ED1ng bi\xEAn \u1EA3i \u0111\xE3 \u0111i\u1EC3m. Qu\u1ED1c
      Tu\u1EA5n, tr\u1EABm l\u1EC7nh cho khanh l\u1EADp t\u1EE9c xu\u1EA5t binh!
      Ph\u1EA3i ch\u1EB7n \u0111\u1EE9ng b\u1EA7y qu\u1EF7 d\u1EEF n\xE0y!\r\n"
  - bongBongUI: {fileID: 1812448428}
    txtNoiDung: {fileID: 3737761}
    noiDungThoai: "<color=#00FFFF>Tr\u1EA7n Qu\u1ED1c Tu\u1EA5n:</color> Th\u1EA7n
      tu\xE2n ch\u1EC9! D\u1EABu m\xE1u ch\u1EA3y \u0111\u1EA7u r\u01A1i, th\u1EA7n
      quy\u1EBFt kh\xF4ng \u0111\u1EC3 b\u1ECDn qu\xE1i v\u1EADt v\u1EA5y b\u1EA9n
      m\u1ED9t t\u1EA5c \u0111\u1EA5t ph\u01B0\u01A1ng Nam!\r\n"
  tocDoGo: 0.05
  daXongHetKichBan: 1
